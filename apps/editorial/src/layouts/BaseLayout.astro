---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Surface — design and technology magazine' } = Astro.props;
const siteUrl = Astro.site ?? 'http://localhost:4321';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} · Surface`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}/og.svg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} · Surface`} />
    <meta name="twitter:image" content={`${siteUrl}/og.svg`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} · Surface</title>
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-white focus:px-3 focus:py-2">
      Skip to content
    </a>
    <SiteHeader />
    <main id="main">
      <slot />
    </main>
    <footer class="border-t border-stone-200 py-10 text-center text-sm text-stone-500">
      <p>Surface Mag — portfolio editorial demo</p>
    </footer>
  </body>
</html>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
