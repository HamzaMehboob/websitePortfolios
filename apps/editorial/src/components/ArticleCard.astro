---
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const date = article.data.pubDate.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
---

<article class="group flex flex-col overflow-hidden rounded-lg border border-stone-200 bg-white">
  {
    article.data.heroImage && (
      <a href={`/articles/${article.id}`} class="block aspect-[16/10] overflow-hidden bg-stone-100">
        <img
          src={article.data.heroImage}
          alt=""
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
        />
      </a>
    )
  }
  <div class="flex flex-1 flex-col gap-3 p-5">
    <div class="flex flex-wrap gap-2 text-xs uppercase tracking-wide text-stone-500">
      {article.data.tags.slice(0, 2).map((tag) => (
        <a href={`/tags/${tag}`} class="hover:text-accent">
          {tag}
        </a>
      ))}
    </div>
    <h2 class="font-serif text-xl font-semibold leading-snug">
      <a href={`/articles/${article.id}`} class="hover:text-accent">
        {article.data.title}
      </a>
    </h2>
    <p class="text-sm text-stone-600">{article.data.description}</p>
    <p class="mt-auto text-xs text-stone-500">
      {date} · <a href={`/authors/${article.data.authorSlug}`} class="hover:text-accent">{article.data.author}</a>
    </p>
  </div>
</article>
