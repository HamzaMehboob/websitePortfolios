---
import { getCollection } from 'astro:content';
import ArticleCard from '../components/ArticleCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const articles = (await getCollection('articles')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featured = articles.filter((a) => a.data.featured);
const recent = articles.filter((a) => !a.data.featured);
---

<BaseLayout title="Home" description="Surface — design and technology magazine for thoughtful builders.">
  <section class="border-b border-stone-200 bg-white">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <p class="text-sm uppercase tracking-[0.2em] text-accent">Design & Technology</p>
      <h1 class="mt-3 max-w-3xl font-serif text-4xl font-semibold leading-tight sm:text-5xl">
        Stories for people who ship interfaces readers love
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-stone-600">
        Surface explores typography, performance, accessibility, and the systems behind polished product UI.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <h2 class="mb-6 font-serif text-2xl font-semibold">Featured</h2>
    <div class="grid gap-8 md:grid-cols-2">
      {featured.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-16 sm:px-6">
    <h2 class="mb-6 font-serif text-2xl font-semibold">Recent</h2>
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {recent.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>
</BaseLayout>
