---
import { getCollection } from 'astro:content';
import ArticleCard from '../../components/ArticleCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { authors, getAuthor } from '../../lib/authors';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return authors.map((author) => ({
    params: { slug: author.slug },
    props: {
      author,
      articles: articles
        .filter((a) => a.data.authorSlug === author.slug)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { author, articles } = Astro.props;
if (!getAuthor(author.slug)) return Astro.redirect('/404');
---

<BaseLayout title={author.name} description={author.bio}>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <p class="text-sm uppercase tracking-wide text-stone-500">Author</p>
    <h1 class="mt-2 font-serif text-4xl font-semibold">{author.name}</h1>
    <p class="mt-1 text-accent">{author.role}</p>
    <p class="mt-4 max-w-2xl text-stone-600">{author.bio}</p>

    <h2 class="mt-12 font-serif text-2xl font-semibold">Articles</h2>
    <div class="mt-6 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {articles.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>
</BaseLayout>
